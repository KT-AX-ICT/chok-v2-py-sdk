# Copy to .env and adjust. Loaded by rca_sdk.config (pydantic-settings, prefix RCA_).

# FastAPI Root URL
FASTAPI_ROOT_URL=http://localhost:8000

# FastAPI 수집 API 엔드포인트 (스냅샷 번들 전송 대상)
RCA_COLLECT_ENDPOINT=${FASTAPI_ROOT_URL}/ingest

# 30초 관측 루프 주기 (초)
RCA_LOOP_INTERVAL_SEC=30

# 메모리 버퍼 롤링 윈도 길이 (초) — 3분 30초
RCA_BUFFER_WINDOW_SEC=210

# 트리거 발화 후 post-trigger 수집 대기 (초) — 3분
RCA_POST_TRIGGER_WAIT_SEC=180

# 동봉 baseline 프로파일 이름 (resources/baselines/<name>.json)
RCA_BASELINE_PROFILE=sn_normal

# 경로는 CWD(실행 위치) 기준으로 풀린다. 이 .env 나 config.py 위치 기준이 아니다.
# 아래 상대경로는 저장소 루트에서 실행할 때만 맞다. 다른 데서 띄운다면 절대경로로 바꾼다.
# (예: C:/chok-v2-py-sdk/var)  — docs/decisions/ADR-004 참조

# 원천 로그 데이터 루트 — 리플레이어 출력이자 tailer가 관측하는 경로. 하위에 log/ metric/ trace/ 를 둔다.
RCA_SOURCE_ROOT=./var

# 전체 데이터셋 루트 — 리플레이어가 읽는 SN 원본
RCA_DATASET_ROOT=./datasets/sn
